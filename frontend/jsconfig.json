{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "components/*": ["./src/components/*"],
      "pages/*": ["./src/pages/*"],
      "contexts/*": ["./src/contexts/*"],
      "lib/*": ["./src/lib/*"],
      "store/*": ["./src/store/*"],
      "utils/*": ["./src/utils/*"],
      "styles/*": ["./src/styles/*"],
      "hooks/*": ["./src/hooks/*"],
      "services/*": ["./src/services/*"],
      "i18n/*": ["./src/i18n/*"]
    },
    "jsx": "react-jsx",
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
